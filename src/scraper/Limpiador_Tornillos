import json

def limpiar_catalogo():
    print("🧹 Iniciando limpieza extrema del catálogo...")
    
    # Tus rutas exactas
    ruta_entrada = r'C:\Users\likan\Desktop\Motion Control\Proyectos\Programa Cercha\Comparador\motordelco-o\data\tornillos_catalogo_profundo.json'
    ruta_salida = r'C:\Users\likan\Desktop\Motion Control\Proyectos\Programa Cercha\Comparador\motordelco-o\data\solo_tornillos.json'
    
    try:
        with open(ruta_entrada, 'r', encoding='utf-8') as f:
            productos = json.load(f)
    except FileNotFoundError:
        print(f"❌ No se encontró el archivo: {ruta_entrada}")
        return

    # Magia de Python: Guardamos el producto SOLO SI la palabra "tornillo" está en el título
    tornillos_puros = []
    for prod in productos:
        titulo = prod.get('titulo', '').lower()
        if 'tornillo' in titulo:
            tornillos_puros.append(prod)

    # Guardamos el nuevo catálogo purificado
    with open(ruta_salida, 'w', encoding='utf-8') as f:
        json.dump(tornillos_puros, f, indent=4, ensure_ascii=False)

    print(f"\n✅ ¡Catálogo Purificado!")
    print(f" - Productos originales con basura: {len(productos)}")
    print(f" - Tornillos puros guardados: {len(tornillos_puros)}")
    print(f" - Basura eliminada: {len(productos) - len(tornillos_puros)} productos")
    print(f"\n📁 Archivo listo en: {ruta_salida}")

if __name__ == "__main__":
    limpiar_catalogo()